DATABASE_URL="postgresql://<user>:<password>@<neon-host>/transitops?sslmode=require"
JWT_SECRET="<random-64-char-string>"
PORT=5050
# Cloudinary (fuel-meter proof photos) — uploads land under transitops/fuel-proofs
CLOUDINARY_CLOUD_NAME="<cloud_name>"
CLOUDINARY_API_KEY="<api_key>"
CLOUDINARY_API_SECRET="<api_secret>"
# Deployed frontend origins for CORS, comma-separated (Vercel)
# CLIENT_ORIGINS="https://your-client.vercel.app"
